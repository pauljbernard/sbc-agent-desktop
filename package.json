{
  "name": "sbcl-agent-ux",
  "productName": "Agent Desktop",
  "version": "0.1.0",
  "private": true,
  "description": "An environment based agentic first development enviornment",
  "author": "Paul Bernard",
  "license": "Apache-2.0",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/electron-vite/bin/electron-vite.js dev",
    "build": "node node_modules/electron-vite/bin/electron-vite.js build",
    "build:app": "npm run build && electron-builder --mac dir",
    "preview": "node node_modules/electron-vite/bin/electron-vite.js preview",
    "typecheck": "tsc --noEmit",
    "test:spec-drift": "node scripts/spec-drift-check.mjs",
    "test:ui": "npm run test:spec-drift && npm run build && playwright test",
    "test:ui:headed": "npm run test:spec-drift && npm run build && playwright test --headed"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^36.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "playwright": "^1.59.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.paulbernard.agentdesktop",
    "productName": "Agent Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "artifactName": "Agent Desktop.${ext}",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        }
      ]
    }
  }
}
