{
  "name": "sbcl-agent-ux",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop frontend for sbcl-agent",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/electron-vite/bin/electron-vite.js dev",
    "build": "node node_modules/electron-vite/bin/electron-vite.js build",
    "preview": "node node_modules/electron-vite/bin/electron-vite.js preview",
    "typecheck": "tsc --noEmit",
    "test:ui": "npm run build && playwright test",
    "test:ui:headed": "npm run build && playwright test --headed"
  },
  "dependencies": {
    "electron": "^36.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "electron-vite": "^3.1.0",
    "playwright": "^1.59.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
